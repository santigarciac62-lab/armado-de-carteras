# Copiá este archivo a .env.local para desarrollo, y configurá las mismas
# variables en Vercel (Project Settings > Environment Variables) para producción.
# Nunca commitear valores reales.

# Clave para firmar la cookie de sesión. Generarla una vez con, por ejemplo:
#   openssl rand -base64 32
AUTH_SECRET=

# Usuarios habilitados, formato "usuario1:clave1,usuario2:clave2"
AUTH_USERS=

# Opcional: activa el conector real de precios (ver src/lib/prices/data912Provider.ts)
USE_DATA912=false

# Opcional: Dashboard Financiero (/dashboard-macro) — ver src/lib/macro/
# Clave gratuita instantánea en https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# IDs de series de datos.gob.ar (ver README, sección Dashboard Financiero,
# antes de setearlas: sin esto esas filas quedan con el valor semilla)
DATOS_GOB_AR_IPC_MENSUAL_ID=
DATOS_GOB_AR_IPC_INTERANUAL_ID=
DATOS_GOB_AR_EMAE_ID=
DATOS_GOB_AR_PBI_INTERANUAL_ID=
